.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ---- Logs / env ----
*.log
.env
.env.*

# Local user preferences (not shared)
backend/userprefs.json

# ---- Desktop build (PyInstaller sidecar) ----
